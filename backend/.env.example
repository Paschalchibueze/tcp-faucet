# Copy this file to .env and fill in your real values
# NEVER commit .env to GitHub

# Your dedicated faucet wallet private key (NOT your main wallet)
FAUCET_PRIVATE_KEY=your_faucet_wallet_private_key_here

# Deployed TCP contract address on BSC Testnet
TOKEN_CONTRACT_ADDRESS=your_tcp_contract_address_here

# hCaptcha secret key from dashboard.hcaptcha.com
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key_here

# Amount of TCP to send per request
FAUCET_AMOUNT_TCP=100

# Your deployed Render frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-frontend.onrender.com

# Port (Render sets this automatically — leave as is)
PORT=3001
